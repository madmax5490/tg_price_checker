# Copy this file to .env and fill in your values
TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# SSL configuration (optional)
# If you're behind a corporate proxy with a self-signed certificate:
#   Option A — point to your proxy's CA bundle (recommended):
#   SSL_CA_BUNDLE=/path/to/proxy-ca.crt
#
#   Option B — disable SSL verification entirely (development only, insecure):
#   SSL_VERIFY=false
